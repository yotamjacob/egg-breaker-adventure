<?xml version="1.0" encoding="utf-8"?>
<!--
    API 31+ Auto-Backup / device-transfer rules.
    Excludes the WebView data directory so Supabase session tokens,
    cookies, and localStorage are not backed up to Google Drive.
    Game progress is restored via the cloud save flow instead.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="app_webview"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="app_webview"/>
    </device-transfer>
</data-extraction-rules>
